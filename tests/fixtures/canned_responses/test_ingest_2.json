import subprocess

def test_tmp_files_deleted():
    """Verify .tmp files are removed."""
    result = subprocess.run(
        ["sh", "-c", "ls /workspace/temp/*.tmp 2>/dev/null | wc -l"],
        capture_output=True, text=True
    )
    assert result.stdout.strip() == "0"

def test_keep_file_preserved():
    """Verify non-.tmp files are preserved."""
    result = subprocess.run(["test", "-f", "/workspace/temp/keep.txt"], capture_output=True)
    assert result.returncode == 0
