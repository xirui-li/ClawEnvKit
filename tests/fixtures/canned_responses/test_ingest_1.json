def test_replacement_done():
    """Verify foo was replaced with bar."""
    with open("/workspace/data.txt") as f:
        content = f.read()
    assert "bar" in content
    assert "foo" not in content

def test_file_not_empty():
    """Verify the file still has content."""
    with open("/workspace/data.txt") as f:
        content = f.read()
    assert len(content.strip()) > 0
