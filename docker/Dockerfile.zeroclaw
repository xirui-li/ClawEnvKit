# ZeroClaw evaluation image
# Build: docker build -f docker/Dockerfile.zeroclaw -t clawenvkit:zeroclaw .
# Run:   docker run --rm -e ANTHROPIC_API_KEY=$KEY \
#          -v ./Auto-ClawEval-mini/todo/todo-001.yaml:/opt/clawenvkit/task.yaml:ro \
#          clawenvkit:zeroclaw
#
# This image is a minimal Debian runtime that copies the `zeroclaw` binary
# from a source image. By default the source image is pulled from GHCR —
# `docker build -f docker/Dockerfile.zeroclaw -t clawenvkit:zeroclaw .`
# just works.
#
# Note on reproducibility: the published `clawenvkit-base-zeroclaw` image is
# built from upstream zeroclaw-labs/zeroclaw at v0.7.4 using a minimal
# Dockerfile we maintain (`COPY . . && cargo build --release --bin zeroclaw
# --no-default-features`), because upstream's official Dockerfile has
# incomplete workspace COPY directives and won't build cleanly in CI. The
# resulting binary is functionally identical for ClawEnvKit eval.
#
# To build from your own source (e.g. a fork), build the upstream image
# locally and override via --build-arg:
#   git clone https://github.com/zeroclaw-labs/zeroclaw.git
#   docker build -f zeroclaw/Dockerfile -t zeroclaw:my-fork zeroclaw
#   docker build -f docker/Dockerfile.zeroclaw \
#     --build-arg BASE_IMAGE=zeroclaw:my-fork \
#     -t clawenvkit:zeroclaw .

# Alias the upstream source image as a build stage so COPY --from below can
# resolve it via the BASE_IMAGE arg.
ARG BASE_IMAGE=ghcr.io/xirui-li/clawenvkit-base-zeroclaw:latest
FROM ${BASE_IMAGE} AS upstream

# ZeroClaw is a minimal binary — use Debian as runtime with zeroclaw binary copied in
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl jq && \
    rm -rf /var/lib/apt/lists/* && \
    pip install --no-cache-dir fastapi uvicorn pyyaml httpx requests pypdf trafilatura

# Copy zeroclaw binary from the upstream source image
COPY --from=upstream /usr/local/bin/zeroclaw /usr/local/bin/zeroclaw

COPY clawenvkit/ /opt/clawenvkit/clawenvkit/
COPY mock_services/ /opt/clawenvkit/mock_services/
COPY mcp_server/mcp_server.py /opt/clawenvkit/mcp_server/mcp_server.py

COPY docker/entrypoint_claw.sh /opt/clawenvkit/entrypoint.sh
RUN chmod +x /opt/clawenvkit/entrypoint.sh

RUN mkdir -p /workspace /logs

ENV TASK_YAML=/opt/clawenvkit/task.yaml
ENV PYTHONPATH=/opt/clawenvkit
ENV PORT=9100
ENV AGENT_NAME=zeroclaw
ENV SKILL_DIR=/root/.zeroclaw/skills/eval-task
ENV AGENT_HOME=/root/.zeroclaw

WORKDIR /workspace
ENTRYPOINT ["/opt/clawenvkit/entrypoint.sh"]
