# ZeroClaw evaluation image
# Build: docker build -f docker/Dockerfile.zeroclaw -t clawenvkit:zeroclaw .
# Run:   docker run --rm -e ANTHROPIC_API_KEY=$KEY -v ./dataset/todo/todo-001.yaml:/opt/clawenvkit/task.yaml:ro clawenvkit:zeroclaw
#
# Prerequisite: docker build -t zeroclaw:latest <path-to-zeroclaw>

# ZeroClaw is a minimal binary — use Debian as runtime with zeroclaw binary copied in
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl jq && \
    rm -rf /var/lib/apt/lists/* && \
    pip install --no-cache-dir fastapi uvicorn pyyaml httpx requests pypdf trafilatura

# Copy zeroclaw binary from its image
COPY --from=zeroclaw:latest /usr/local/bin/zeroclaw /usr/local/bin/zeroclaw

COPY clawenvkit/ /opt/clawenvkit/clawenvkit/
COPY mock_services/ /opt/clawenvkit/mock_services/
COPY mcp_server/mcp_server.py /opt/clawenvkit/mcp_server/mcp_server.py

COPY docker/entrypoint_claw.sh /opt/clawenvkit/entrypoint.sh
RUN chmod +x /opt/clawenvkit/entrypoint.sh

RUN mkdir -p /workspace /logs

ENV TASK_YAML=/opt/clawenvkit/task.yaml
ENV PYTHONPATH=/opt/clawenvkit
ENV PORT=9100
ENV AGENT_NAME=zeroclaw
ENV SKILL_DIR=/root/.zeroclaw/skills/eval-task
ENV AGENT_HOME=/root/.zeroclaw

WORKDIR /workspace
ENTRYPOINT ["/opt/clawenvkit/entrypoint.sh"]
