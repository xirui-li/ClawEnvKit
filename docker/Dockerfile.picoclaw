# PicoClaw evaluation image
# Build: docker build -f docker/Dockerfile.picoclaw -t claw-harness-picoclaw .
# Run:   docker run --rm -e ANTHROPIC_API_KEY=$KEY -v ./dataset/todo/todo-001.yaml:/opt/clawharness/task.yaml:ro claw-harness-picoclaw
#
# Prerequisite: docker build -t picoclaw:latest <path-to-picoclaw>

FROM picoclaw:latest

USER root

RUN apk add --no-cache python3 py3-pip curl jq && \
    pip3 install --no-cache-dir --break-system-packages \
    fastapi uvicorn pyyaml httpx requests pypdf trafilatura

COPY clawharness/ /opt/clawharness/clawharness/
COPY mock_services/ /opt/clawharness/mock_services/

COPY docker/entrypoint_claw.sh /opt/clawharness/entrypoint.sh
RUN chmod +x /opt/clawharness/entrypoint.sh

RUN mkdir -p /workspace /logs && \
    chown -R root:root /opt/clawharness /workspace /logs

ENV TASK_YAML=/opt/clawharness/task.yaml
ENV PYTHONPATH=/opt/clawharness
ENV PORT=9100
ENV AGENT_NAME=picoclaw
ENV AGENT_CMD="picoclaw agent"
ENV SKILL_DIR=/root/.picoclaw/skills/eval-task
ENV AGENT_HOME=/root/.picoclaw

WORKDIR /workspace
ENTRYPOINT ["/opt/clawharness/entrypoint.sh"]
