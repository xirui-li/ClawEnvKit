# PicoClaw evaluation image
# Build: docker build -f docker/Dockerfile.picoclaw -t clawenvkit:picoclaw .
# Run:   docker run --rm -e ANTHROPIC_API_KEY=$KEY \
#          -v ./Auto-ClawEval-mini/todo/todo-001.yaml:/opt/clawenvkit/task.yaml:ro \
#          clawenvkit:picoclaw
#
# Prerequisite — build the upstream PicoClaw base image. The upstream repo ships
# multiple variants; this harness only needs the Alpine final stage, so the
# minimal `docker/Dockerfile` is sufficient:
#   git clone https://github.com/sipeed/picoclaw.git
#   docker build -f picoclaw/docker/Dockerfile -t picoclaw:latest picoclaw
#
# (Use Dockerfile.full or Dockerfile.heavy only if you need node/extra tools
# in the base — neither is required by this harness.)
#
# Or override the base via build-arg:
#   docker build -f docker/Dockerfile.picoclaw \
#     --build-arg BASE_IMAGE=ghcr.io/xirui-li/clawenvkit-base-picoclaw:latest \
#     -t clawenvkit:picoclaw .

ARG BASE_IMAGE=picoclaw:latest
FROM ${BASE_IMAGE}

USER root

RUN apk add --no-cache python3 py3-pip curl jq bash && \
    pip3 install --no-cache-dir --break-system-packages \
    fastapi uvicorn pyyaml httpx requests pypdf trafilatura

COPY clawenvkit/ /opt/clawenvkit/clawenvkit/
COPY mock_services/ /opt/clawenvkit/mock_services/
COPY mcp_server/mcp_server.py /opt/clawenvkit/mcp_server/mcp_server.py

COPY docker/entrypoint_claw.sh /opt/clawenvkit/entrypoint.sh
RUN chmod +x /opt/clawenvkit/entrypoint.sh

RUN mkdir -p /workspace /logs && \
    chown -R root:root /opt/clawenvkit /workspace /logs

ENV TASK_YAML=/opt/clawenvkit/task.yaml
ENV PYTHONPATH=/opt/clawenvkit
ENV PORT=9100
ENV AGENT_NAME=picoclaw
ENV SKILL_DIR=/root/.picoclaw/skills/eval-task
ENV AGENT_HOME=/root/.picoclaw

WORKDIR /workspace
ENTRYPOINT ["/opt/clawenvkit/entrypoint.sh"]
