# NanoClaw evaluation image
# Build: docker build -f docker/Dockerfile.nanoclaw -t clawenvkit:nanoclaw .
# Run:   docker run --rm -e ANTHROPIC_API_KEY=$KEY \
#          -v ./Auto-ClawEval-mini/todo/todo-001.yaml:/opt/clawenvkit/task.yaml:ro \
#          clawenvkit:nanoclaw
#
# Prerequisite — build the upstream NanoClaw base image. NanoClaw's Dockerfile
# lives in container/ and references agent-runner/ as a sibling, so the build
# context must be container/, not the repo root:
#   git clone https://github.com/qwibitai/nanoclaw.git
#   docker build -f nanoclaw/container/Dockerfile -t nanoclaw:latest nanoclaw/container
#
# Or override the base via build-arg:
#   docker build -f docker/Dockerfile.nanoclaw \
#     --build-arg BASE_IMAGE=ghcr.io/xirui-li/clawenvkit-base-nanoclaw:latest \
#     -t clawenvkit:nanoclaw .

ARG BASE_IMAGE=nanoclaw:latest
FROM ${BASE_IMAGE}

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip curl jq \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir --break-system-packages \
    fastapi uvicorn pyyaml httpx requests pypdf trafilatura

# ClawEnvKit infrastructure
COPY clawenvkit/ /opt/clawenvkit/clawenvkit/
COPY mock_services/ /opt/clawenvkit/mock_services/
COPY mcp_server/mcp_server.py /opt/clawenvkit/mcp_server/mcp_server.py

COPY docker/entrypoint_claw.sh /opt/clawenvkit/entrypoint.sh
RUN chmod +x /opt/clawenvkit/entrypoint.sh

RUN mkdir -p /workspace /logs && \
    chown -R root:root /opt/clawenvkit /workspace /logs

ENV TASK_YAML=/opt/clawenvkit/task.yaml
ENV PYTHONPATH=/opt/clawenvkit
ENV PORT=9100
ENV AGENT_NAME=nanoclaw
ENV SKILL_DIR=/root/.nanoclaw/workspace/skills/eval-task
ENV AGENT_HOME=/root/.nanoclaw

WORKDIR /workspace
ENTRYPOINT ["/opt/clawenvkit/entrypoint.sh"]
